# ==============================================================================
# Android UI Exploration Agent - Environment Variables Configuration
# ==============================================================================
# Copy this file to '.env' and fill in your settings.

# Mode: "ollama" (local) or "open-ai-compatible"
EXPLORATION_MODE=open-ai-compatible

# ------------------------------------------------------------------------------
# OpenAI or OpenAI-Compatible Settings
# ------------------------------------------------------------------------------
# Required when EXPLORATION_MODE=open-ai-compatible
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ------------------------------------------------------------------------------
# Ollama settings (Local LLM)
# ------------------------------------------------------------------------------
# Required when EXPLORATION_MODE=ollama
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen3:8b

# ------------------------------------------------------------------------------
# Application Exploration Settings
# ------------------------------------------------------------------------------
# The package name of the target Android application
TARGET_PACKAGE=com.shadowings.gero

# Filepaths for agent prompts and configurations (relative or absolute)
APP_CONTEXT_FILE=prompts/APP_CONTEXT.md
EXPLORATION_PROMPT_FILE=prompts/EXPLORATION_PROMPT.md
GOALS_DIR=goals
